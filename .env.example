# Quote service — environment template. Copy to .env.local and fill in real values.
# .env.local is gitignored; never commit real secrets.

# --- Supabase (quote's own project) ---
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Settings → API → Project API keys → service_role / secret  (SERVER-ONLY, keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (quote-branded client) ---
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# --- blind-bot server (used server-side for email-based account linking) ---
BLINDBOT_API_URL=https://your-blind-bot-server.example.com

# --- blind-bot handoff (THE-772) ---
# Shared HMAC secret — must MATCH the value on blind-bot-server. Verifies the signed
# handoff token (inbound POST /api/handoff and reverse GET /api/handoff/callback).
QUOTE_HANDOFF_SECRET=shared-secret-identical-on-blind-bot-server
# blind-bot frontend origin — enables the "Continue with BlindBot" button on /login,
# which bounces to {this}/authorize-quote. Leave unset to hide the button.
NEXT_PUBLIC_BLINDBOT_FRONTEND_URL=http://localhost:3000

# --- White-label brand (retailer-facing). Defaults to "Loom & Shade" if unset. ---
NEXT_PUBLIC_BRAND_NAME=Loom & Shade
NEXT_PUBLIC_BRAND_TAGLINE=Trade Portal
NEXT_PUBLIC_BRAND_MONOGRAM=LS

# Comma-separated hostnames /api/img is allowed to proxy. Must include the host the
# blind-bot result image is served from. Defaults to the BLINDBOT_API_URL host if unset.
IMG_PROXY_ALLOWED_HOSTS=
